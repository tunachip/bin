#!/usr/bin/env bash

source ~/.local/share/theme/colors.sh

IP_VISIBILITY_FILE="${XDG_RUNTIME_DIR:-/tmp}/statusbar-ip-visible"

while true; do
    # === WIFI / IP ===
    IP=$(ip -4 addr show wlan0 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
    if [ -n "$IP" ]; then
        if [ "$(cat "$IP_VISIBILITY_FILE" 2>/dev/null)" = "1" ]; then
            WIFI="| ï‡«  $IP |"
        else
            WIFI="| ï‡«  connected |"
        fi
    else
        WIFI=" ï‡«  not connected  "
    fi

    # === BATTERY ===
    BAT=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
    if [ -n "$BAT" ]; then
        if [ "$BAT" -lt 20 ]; then
            BAT_COLOR="$RED"
        elif [ "$BAT" -lt 50 ]; then
            BAT_COLOR="$YELLOW"
        else
            BAT_COLOR="$GREEN"
        fi
        BATTERY=" <span foreground=\"$BAT_COLOR\">َ°پ¹ $BAT%</span> |"
    else
        BATTERY=""
    fi

    # === VOLUME ===
    VOL_INFO=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
    VOL=$(awk '{printf "%d", $2 * 100}' <<<"$VOL_INFO")
    VOL_FMT=$(printf "%3d" "$VOL")
    if [[ "$VOL_INFO" == *"[MUTED]"* ]] || [ "$VOL" -eq 0 ]; then
        SOUND=" <span foreground=\"$RED\">َ°–پ</span> ${VOL_FMT}% |"
    else
        SOUND=" َ°•¾ ${VOL_FMT}% |"
    fi

    # === TIME ===
    TIME=" َ°¥” $(date '+%H:%M:%S') "

    # === JSON OUTPUT ===
    echo "$WIFI$BATTERY$SOUND$TIME"

    sleep 1
done
