#!/usr/bin/env bash

source ~/.local/share/theme/colors.sh

while true; do
    # === WIFI / IP ===
    IP=$(ip -4 addr show wlan0 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
    if [ -n "$IP" ]; then
        WIFI="| ï‡«  $IP |"
    else
        WIFI=" ï‡« not connected   "
    fi

    # === BATTERY ===
    BAT=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
    if [ -n "$BAT" ]; then
        if [ "$BAT" -lt 20 ]; then
            BAT_COLOR="$RED"
        elif [ "$BAT" -lt 50 ]; then
            BAT_COLOR="$YELLOW"
        else
            BAT_COLOR="$GREEN"
        fi
        BATTERY=" <span foreground=\"$BAT_COLOR\">َ°پ¹ $BAT%</span> |"
    else
        BATTERY=""
    fi
    # === VOLUME ===
    VOL=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf "%d", $2*100}')
    SOUND=" َ°•¾ $VOL% |"
    # === TIME ===
    TIME=" َ°¥” $(date '+%H:%M:%S') "
    # === JSON OUTPUT ===
    echo "$WIFI$BATTERY$SOUND$TIME"

    sleep 1
done
