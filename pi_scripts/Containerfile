FROM docker.io/library/node:24-bookworm

ARG PI_AGENT_VERSION=0.70.2

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    fd-find \
    git \
    iproute2 \
    jq \
    less \
    locales \
    nano \
    neovim \
    openssh-client \
    openssh-server \
    procps \
    python3 \
    python3-pip \
    ripgrep \
    rsync \
    sudo \
    tmux \
    unzip \
    vim-tiny \
    zsh \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g "@mariozechner/pi-coding-agent@${PI_AGENT_VERSION}" \
  && npm cache clean --force

RUN mkdir -p /workspace /pi-agent /run/sshd /var/run/sshd \
  && chmod 755 /workspace /pi-agent

WORKDIR /workspace

CMD ["sh", "-lc", "mkdir -p /run/sshd /var/run/sshd; exec /usr/sbin/sshd -D -e -f /pi-agent/ssh/sshd_config"]
