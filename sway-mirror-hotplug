#!/usr/bin/env sh
set -eu

# Keep only one watcher instance across config reloads.
exec 9>/tmp/sway-output-hotplug.lock
flock -n 9 || exit 0

log_file="/tmp/sway-output-hotplug.log"

log() {
    printf '%s %s\n' "$(date '+%F %T')" "$*" >>"$log_file"
}

apply_output_policy() {
    outputs_json="$(swaymsg -t get_outputs -r)"

    internal_output="$(printf '%s\n' "$outputs_json" | jq -r '.[] | select(.name | test("^(eDP|LVDS)")) | .name' | head -n1)"
    external_outputs="$(printf '%s\n' "$outputs_json" | jq -r '.[] | select(.name | test("^(eDP|LVDS)") | not) | .name')"
    primary_external="$(printf '%s\n' "$external_outputs" | head -n1)"

    best_mode_for() {
        output_name="$1"

        printf '%s\n' "$outputs_json" | jq -r --arg output_name "$output_name" '
            .[]
            | select(.name == $output_name)
            | ([ .modes[]? ] | sort_by((.width * .height), .refresh) | last)
            | select(. != null)
            | "\(.width)x\(.height)@\(.refresh / 1000)Hz"
        ' | head -n1
    }

    log "internal=${internal_output:-none} external=${primary_external:-none}"

    if [ -n "$primary_external" ]; then
        external_mode="$(best_mode_for "$primary_external")"
        log "external_mode=${external_mode:-auto}"

        if [ -n "$external_mode" ]; then
            swaymsg "output $primary_external mode $external_mode scale 1 enable pos 0 0" >/dev/null
        else
            swaymsg "output $primary_external enable pos 0 0" >/dev/null
        fi
        [ -n "$internal_output" ] && swaymsg "output $internal_output disable" >/dev/null
        printf '%s\n' "$external_outputs" | while IFS= read -r out; do
            [ -n "$out" ] || continue
            [ "$out" = "$primary_external" ] && continue
            swaymsg "output $out disable" >/dev/null
        done
        return
    fi

    [ -n "$internal_output" ] || exit 0
    swaymsg "output $internal_output enable pos 0 0" >/dev/null

    printf '%s\n' "$outputs_json" | jq -r '.[] | select(.name | test("^(eDP|LVDS)") | not) | .name' \
        | while IFS= read -r out; do
            [ -n "$out" ] || continue
            swaymsg "output $out disable" >/dev/null
        done
}

if [ "${1:-}" = "--once" ]; then
    apply_output_policy
    exit 0
fi

apply_output_policy
swaymsg -m -t subscribe '["output"]' \
    | while IFS= read -r _; do
        sleep 1
        apply_output_policy
    done
