#!/usr/bin/env bash
set -euo pipefail

MENU="${MENU:-${HOME}/.local/bin/menus/_fzf_i3.sh}"
LOCK_CMD="${LOCK_CMD:-i3lock}"
LOGOUT_CMD="${LOGOUT_CMD:-i3-msg exit}"

choice="$(
  cat <<'EOF' | "$MENU" -p "power"
lock
logout
reboot
shutdown
EOF
)"

case "${choice:-}" in
  lock) exec ${=LOCK_CMD} ;;
  logout) exec ${=LOGOUT_CMD} ;;
  reboot) exec systemctl reboot ;;
  shutdown) exec systemctl poweroff ;;
  *) exit 0 ;;
esac
